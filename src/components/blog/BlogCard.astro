---
// src/components/blog/BlogCard.astro
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: string;
  tags: string[];
  readTime?: string;
  slug: string;
}
const { title, description, pubDate, heroImage, tags, readTime, slug } = Astro.props;
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="content-card blog-card bg-white shadow-light overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-medium flex flex-col">
  <div class="card-image relative overflow-hidden" style="height: 220px;">
    <img
      src={heroImage || 'https://images.pexels.com/photos/159711/books-bookstore-book-reading-159711.jpeg?auto=compress&cs=tinysrgb&w=400&h=250&fit=crop'}
      alt={title}
      width="400"
      height="220"
      class="w-full h-full object-cover"
      loading="lazy"
    />
    {readTime && (
      <div class="card-overlay absolute top-4 right-4">
        <span class="read-time text-xs bg-black/60 text-white px-3 py-1 rounded-full">{readTime}</span>
      </div>
    )}
  </div>
  <div class="card-content p-6 flex flex-col flex-1">
    <div class="card-meta flex items-start justify-between gap-2 mb-3">
      <span class="date text-sm text-on-surface-variant">{formattedDate}</span>
      <div class="tags flex flex-wrap gap-1">
        {tags.map((tag) => (
          <span class="tag text-xs px-2 py-1 rounded-full font-medium bg-surface-container text-on-surface-variant">{tag}</span>
        ))}
      </div>
    </div>
    <h3 class="text-lg font-medium text-on-surface mb-2">
      <a href={`/blog/${slug}`} class="text-on-surface hover:text-on-surface transition-colors no-underline" style="min-width:unset; min-height:unset;">{title}</a>
    </h3>
    <p class="summary text-on-surface-variant text-sm leading-relaxed flex-1">{description}</p>
    <a
      href={`/blog/${slug}`}
      class="read-more mt-4 text-secondary font-medium text-sm hover:underline"
      style="min-width:unset; min-height:unset; display:inline;"
    >
      Read More →
    </a>
  </div>
</article>
