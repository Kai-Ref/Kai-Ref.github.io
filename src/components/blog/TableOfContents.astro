---
// src/components/blog/TableOfContents.astro
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props {
  headings: Heading[];
}
const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 0 && (
  <nav aria-label="Table of contents" class="toc">
    <p class="toc-label">Contents</p>
    <ol class="toc-list" role="list">
      {filtered.map((heading) => (
        <li class={heading.depth === 3 ? 'toc-item toc-item-nested' : 'toc-item'}>
          <a
            href={`#${heading.slug}`}
            class="toc-link"
            style="min-width:unset; min-height:unset"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc {
    border-left: 1px solid rgba(26, 28, 28, 0.12);
    padding-left: 1rem;
  }
  .toc-label {
    font-family: 'Inter', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.7rem;
    color: #ae3100;
    margin-bottom: 0.8rem;
  }
  .toc-list {
    list-style: none;
    display: grid;
    gap: 0.42rem;
  }
  .toc-item {
    margin: 0;
  }
  .toc-item-nested {
    padding-left: 0.9rem;
  }
  .toc-link {
    min-height: unset;
    min-width: unset;
    display: block;
    text-decoration: none;
    color: rgba(26, 28, 28, 0.7);
    font-family: 'Manrope', sans-serif;
    font-size: 0.9rem;
    line-height: 1.4;
    transition: color 0.2s ease;
  }
  .toc-link:hover {
    color: #ae3100;
  }
  @media (max-width: 1023px) {
    .toc {
      display: none;
    }
  }
</style>
