---
// src/components/layout/Sidebar.astro
import RotatingText from './RotatingText.tsx';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/portfolio', label: 'Experience' },
  { href: '/projects', label: 'Projects' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

const currentPath = Astro.url.pathname;
---

<aside
  class="sidebar w-[280px] fixed h-screen z-[100] flex flex-col justify-between py-8 px-6"
  style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%); color: white; box-shadow: var(--shadow-medium);"
  aria-label="Site navigation"
>
  <!-- Mobile toggle -->
  <button
    class="menu-toggle absolute top-4 right-4 text-white text-2xl bg-transparent border-0 cursor-pointer hidden"
    aria-label="Toggle navigation menu"
    id="menu-toggle"
  >
    ☰
  </button>

  <div>
    <!-- Profile -->
    <div class="text-center mb-12">
      <img
        src="/img/profile_pics/profile_pic.jpg"
        alt="Kai Reffert profile picture"
        width="120"
        height="120"
        class="rounded-full mx-auto mb-6 object-cover border-4 transition-transform duration-300 hover:scale-105"
        style="border-color: rgba(255,255,255,0.2);"
      />
      <h1 class="text-2xl font-semibold mb-2">Kai Reffert</h1>
      <RotatingText client:load />
    </div>

    <!-- Navigation -->
    <nav aria-label="Main navigation">
      <ul class="list-none mb-8 space-y-2">
        {navLinks.map(({ href, label }) => {
          const isActive =
            href === '/'
              ? currentPath === '/' || currentPath === '/index'
              : currentPath.startsWith(href);
          return (
            <li>
              <a
                href={href}
                class:list={[
                  'block text-white/90 no-underline font-medium px-4 py-3 rounded-lg transition-all duration-300',
                  isActive
                    ? 'bg-white/10 text-white translate-x-[5px]'
                    : 'hover:bg-white/10 hover:text-white hover:translate-x-[5px]',
                ]}
                aria-current={isActive ? 'page' : undefined}
                style="min-width: unset; min-height: unset;"
              >
                {label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>

  <!-- Contact Icons -->
  <div class="flex justify-center gap-4" style="color: rgba(255,255,255,0.7);">
    <a
      href="mailto:kai.reffert@gmail.com"
      aria-label="Send email to Kai Reffert"
      class="hover:text-white transition-colors duration-300"
      style="min-width:unset; min-height:unset;"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.89 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
      </svg>
    </a>
    <a
      href="https://www.linkedin.com/in/kai-reffert"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Kai Reffert on LinkedIn"
      class="hover:text-white transition-colors duration-300"
      style="min-width:unset; min-height:unset;"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>
    <a
      href="https://github.com/kai-ref"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Kai Reffert on GitHub"
      class="hover:text-white transition-colors duration-300"
      style="min-width:unset; min-height:unset;"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
    </a>
  </div>
</aside>

<script>
  const toggle = document.getElementById('menu-toggle');
  const sidebar = document.querySelector('.sidebar');
  toggle?.addEventListener('click', () => sidebar?.classList.toggle('open'));
</script>

<style>
  @media (max-width: 768px) {
    .sidebar {
      left: -100%;
      transition: left 0.3s ease;
    }
    .sidebar.open {
      left: 0;
    }
    .menu-toggle {
      display: block !important;
    }
  }
</style>
