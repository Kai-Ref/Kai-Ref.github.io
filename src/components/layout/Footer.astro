---
// src/components/layout/Footer.astro
---

<footer class="bg-primary-container px-6 md:px-12 py-10 md:py-16">
  <div class="max-w-screen-xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">

      <!-- Column 1: Brand -->
      <div>
        <p class="font-headline text-xl font-light tracking-tighter text-white">Kai Reffert</p>
        <p class="font-label text-xs tracking-widest uppercase text-white/50 mt-2">
          Data Scientist &amp; AI Enthusiast
        </p>
      </div>

      <!-- Column 2: Navigation -->
      <div>
        <p class="font-label text-xs tracking-widest uppercase text-white/40 mb-4">Navigate</p>
        <ul class="space-y-2 list-none p-0 m-0">
          <li><a href="/about" class="font-label text-sm text-white/70 hover:text-white transition-colors no-underline">About</a></li>
          <li><a href="/portfolio" class="font-label text-sm text-white/70 hover:text-white transition-colors no-underline">Experience</a></li>
          <li><a href="/projects" class="font-label text-sm text-white/70 hover:text-white transition-colors no-underline">Projects</a></li>
          <li><a href="/blog" class="font-label text-sm text-white/70 hover:text-white transition-colors no-underline">Blog</a></li>
        </ul>
      </div>

      <!-- Column 3: Social -->
      <div>
        <p class="font-label text-xs tracking-widest uppercase text-white/40 mb-4">Connect</p>
        <ul class="space-y-2 list-none p-0 m-0">
          <li>
            <a
              href="https://www.linkedin.com/in/kai-reffert"
              target="_blank"
              rel="noopener noreferrer"
              class="font-label text-sm text-white/70 hover:text-white transition-colors no-underline"
            >LinkedIn</a>
          </li>
          <li>
            <a
              href="https://github.com/kai-ref"
              target="_blank"
              rel="noopener noreferrer"
              class="font-label text-sm text-white/70 hover:text-white transition-colors no-underline"
            >GitHub</a>
          </li>
          <li>
            <a
              href="mailto:kai.reffert@gmail.com"
              class="font-label text-sm text-white/70 hover:text-white transition-colors no-underline"
            >Email</a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 mt-12 pt-6">
      <p class="font-label text-xs text-white/30 text-center">© 2025 Kai Reffert</p>
    </div>
  </div>
</footer>
