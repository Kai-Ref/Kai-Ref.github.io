---
// src/components/layout/BaseLayout.astro
import '../../styles/global.css';
import Footer from './Footer.astro';

interface Props {
  title: string;
  description?: string;
  canonicalURL?: string;
  ogType?: string;
  structuredData?: object;
  breadcrumbs?: Array<{ name: string; url: string }>;
}

const {
  title,
  description = 'Kai Reffert — M.Sc. Data Science student and AI innovator.',
  canonicalURL,
  ogType = 'website',
  structuredData,
  breadcrumbs,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="jGluHUPBuofNXlZQyV2UaZLpW1X2uu2YNsH36-jCSs8" />
    <meta name="google-site-verification" content="3bxh3cQZB5kz95iFiPdDOXrXjFJbxhjPjYQqkZ5KwYE" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Kai Reffert" />
    <meta name="robots" content="index, follow" />
    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    {canonicalURL && <meta property="og:url" content={canonicalURL} />}
    <meta property="og:site_name" content="Kai Reffert" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Structured data -->
    {structuredData && (
      <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}

    <!-- BreadcrumbList structured data -->
    {breadcrumbs && breadcrumbs.length > 0 && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbs.map((crumb, i) => ({
          "@type": "ListItem",
          "position": i + 1,
          "name": crumb.name,
          "item": crumb.url,
        })),
      })} />
    )}

    <!-- RSS feed -->
    <link rel="alternate" type="application/rss+xml" title="Kai Reffert — Blog" href="/rss.xml" />

    <!-- Google Fonts: Newsreader (serif) + Manrope (body) + Inter (label) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,200..800;1,6..72,200..800&family=Manrope:wght@200..800&family=Inter:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <!-- Material Symbols Outlined (thin weight, for icons) -->
    <link
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
      rel="stylesheet"
    />

    <!-- Critical animation + icon styles -->
    <style is:global>
      .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 200, 'GRAD' 0, 'opsz' 24;
      }
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
      }
      .hero-fade-in { animation: fadeInUp 0.6s ease forwards; }
    </style>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-surface text-on-surface">
    <slot />
    <Footer />
  </body>
</html>
