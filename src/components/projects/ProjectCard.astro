---
// src/components/projects/ProjectCard.astro
interface Props {
  title: string;
  description: string;
  image: string;
  technologies: string[];
  date: string;
  status: string;
  github: string | null;
  demo: string | null;
}
const { title, description, image, technologies, date, status, github, demo } = Astro.props;
const isVideo = image.toLowerCase().endsWith('.mp4');
---

<article class="content-card project-card bg-white shadow-light overflow-hidden transition-all duration-300 hover:-translate-y-2 hover:shadow-medium flex flex-col">
  <div class="card-image relative overflow-hidden group" style="height: 220px;">
    {isVideo ? (
      <video
        src={image}
        aria-label={title}
        width="400"
        height="220"
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
      />
    ) : (
      <img
        src={image}
        alt={title}
        width="400"
        height="220"
        class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
        loading="lazy"
      />
    )}
    <div class="card-overlay absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-4">
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${title} on GitHub`}
          class="text-white hover:text-secondary transition-colors"
          style="min-width:unset; min-height:unset;"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      )}
      {demo && (
        <a
          href={demo}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${title} demo`}
          class="text-white hover:text-secondary transition-colors"
          style="min-width:unset; min-height:unset;"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      )}
    </div>
  </div>
  <div class="card-content p-6 flex flex-col flex-1">
    <div class="card-meta flex items-center justify-between mb-3">
      <span class="date text-sm text-on-surface-variant">{date}</span>
      <div class="tech-stack flex flex-wrap gap-1">
        {technologies.slice(0, 3).map((tech) => (
          <span class="tech-tag text-xs px-2 py-1 rounded-full font-medium bg-surface-container text-on-surface-variant">{tech}</span>
        ))}
      </div>
    </div>
    <h3 class="font-body text-lg font-medium text-on-surface mb-2">{title}</h3>
    <p class="summary text-on-surface-variant text-sm leading-relaxed flex-1">{description}</p>
    <div class="project-status mt-4">
      <span class="status text-xs px-3 py-1 rounded-full font-medium bg-surface-container text-on-surface-variant">
        {status}
      </span>
    </div>
  </div>
</article>
