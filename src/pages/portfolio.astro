---
// src/pages/portfolio.astro
import BaseLayout from '../components/layout/BaseLayout.astro';
import TopNav from '../components/layout/TopNav.astro';
import PortfolioMap from '../components/portfolio/map/PortfolioMap';

const canonicalURL = 'https://kai-ref.github.io/portfolio/';
const breadcrumbs = [
  { name: 'Home', url: 'https://kai-ref.github.io/' },
  { name: 'Experience', url: canonicalURL },
];
---

<BaseLayout
  title="Experience | Kai Reffert"
  description="Kai Reffert's professional and educational timeline."
  canonicalURL={canonicalURL}
  breadcrumbs={breadcrumbs}
>
  <TopNav />

  <main class="main-content flex-1 min-h-screen" aria-label="Portfolio map timeline">
    <PortfolioMap client:load />
  </main>
</BaseLayout>
