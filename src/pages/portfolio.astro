---
// src/pages/portfolio.astro
import { getCollection } from 'astro:content';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import BaseLayout from '../components/layout/BaseLayout.astro';
import TopNav from '../components/layout/TopNav.astro';
import TimelineExperience from '../components/portfolio/TimelineExperience/TimelineExperience';
import { serializeTimelineEntry } from '../components/portfolio/TimelineExperience/serialize.js';

const timelineEntries = await getCollection('timeline', (entry) => !entry.id.startsWith('_'));
const markdown = await createMarkdownProcessor();
const initialEntries = await Promise.all(
  timelineEntries.map(async (entry) => {
    const rendered = await markdown.render(entry.body, {
      fileURL: new URL(`../content/timeline/${entry.id}`, import.meta.url),
      frontmatter: entry.data,
    });

    return serializeTimelineEntry(entry, rendered.code);
  })
);

const canonicalURL = 'https://kai-ref.github.io/portfolio/';
const breadcrumbs = [
  { name: 'Home', url: 'https://kai-ref.github.io/' },
  { name: 'Experience', url: canonicalURL },
];
---

<BaseLayout
  title="Experience | Kai Reffert"
  description="Kai Reffert's professional and educational timeline."
  canonicalURL={canonicalURL}
  breadcrumbs={breadcrumbs}
>
  <TopNav />

  <main class="main-content flex-1 min-h-screen bg-bg-secondary" aria-label="Portfolio timeline">
    <TimelineExperience client:load initialEntries={initialEntries} />
  </main>
</BaseLayout>
